<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Trivia Night local multiplayer (DNS-SD discovery + TCP sockets; Wi-Fi Aware). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE"/>
    <!-- Wi-Fi Aware is optional — the app falls back to DNS-SD + TCP without it. -->
    <uses-feature android:name="android.hardware.wifi.aware" android:required="false"/>

    <!-- Bluetooth LE — the "no Wi-Fi at all" Trivia Night fallback (Android 12+ perms). -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"/>
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false"/>
    <!-- NSD discovery reveals nearby devices; Android 13+ gates it behind this
         runtime permission (neverForLocation = we don't derive location). -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"/>

    <application
        android:name=".app.AppNameApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppName.Splash"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.AppName.Splash"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- App Links (HTTPS) — autoVerify against
                 https://tidbitstrivia.com/.well-known/assetlinks.json. The
                 assetlinks file must list the Play App Signing SHA-256 (from
                 Play Console -> App integrity) for installs from Play to verify;
                 the upload-key fingerprint covers local/sideloaded builds. Until
                 the Play cert is added, these open via the chooser (still work),
                 they just aren't auto-verified. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="tidbitstrivia.com"/>
                <data android:scheme="https" android:host="www.tidbitstrivia.com"/>
            </intent-filter>

            <!-- Custom scheme — App Shortcuts + same-app deep links (DEEP_LINKS.md). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="tidbits"/>
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts"/>
        </activity>

        <!-- Firebase Messaging service goes here when push ships -->
        <!--
        <service
            android:name=".notifications.AppFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>
        -->

    </application>

    <!-- Required for opening Custom Tabs / Discord / web links on Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService"/>
        </intent>
    </queries>

</manifest>
