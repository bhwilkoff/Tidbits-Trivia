<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required perms ship empty; add per-feature as you wire them up. -->
    <!-- <uses-permission android:name="android.permission.INTERNET"/> auto-granted -->
    <!-- <uses-permission android:name="android.permission.CAMERA"/> for Scan -->
    <!-- <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/> for FCM -->

    <application
        android:name=".app.AppNameApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppName.Splash"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.AppName.Splash"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- App Links (HTTPS, autoVerify against .well-known/assetlinks.json).
                 FILL IN your domain + path prefixes. -->
            <!--
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="example.com"/>
            </intent-filter>
            -->

            <!-- Custom scheme deep links (OAuth callbacks, same-app deep links). -->
            <!--
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="appname"/>
            </intent-filter>
            -->
        </activity>

        <!-- Firebase Messaging service goes here when push ships -->
        <!--
        <service
            android:name=".notifications.AppFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>
        -->

    </application>

    <!-- Required for opening Custom Tabs / Discord / web links on Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService"/>
        </intent>
    </queries>

</manifest>
