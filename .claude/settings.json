{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(awk *)",
      "Bash(sed *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git ls-files*)",
      "Bash(git add *)",
      "Bash(git restore*)",

      "Bash(python3 -m http.server *)",
      "Bash(node js/*)",
      "Bash(npm test*)",
      "Bash(npx *)",

      "Bash(./gradlew *)",
      "Bash(cd android && ./gradlew *)",
      "Bash(gradle *)",

      "Bash(xcrun simctl list*)",
      "Bash(xcrun simctl boot *)",
      "Bash(xcrun simctl install *)",
      "Bash(xcrun simctl launch *)",
      "Bash(xcrun simctl screenshot *)",
      "Bash(xcodebuild -list*)",
      "Bash(xcodebuild -showBuildSettings*)",
      "Bash(xcodebuild test *)",
      "Bash(xcodebuild build *)",

      "Bash(adb devices*)",
      "Bash(adb shell *)",
      "Bash(adb logcat*)",
      "Bash(adb install *)",
      "Bash(adb uninstall *)",
      "Bash(adb push *)",
      "Bash(adb pull *)",

      "Bash(open *)",
      "Bash(./tools/refresh-skills.sh)",
      "Bash(./tools/install-android-skills.sh)",
      "Bash(bash ./android/scripts/sync_shared_assets.sh)"
    ]
  }
}
