# Environment / secrets
.env
.env.local
*.key
credentials.json

# Android — Gradle wrapper jar is committed via android/.gitignore exception;
# everything else is generated. Per-module .gitignore in android/ owns the
# canonical list — duplicate the top entries here so a clone-then-rm-android
# user doesn't accidentally commit caches.
android/.gradle/
android/.idea/
android/build/
android/**/build/
android/local.properties
# gradle-wrapper.jar IS committed — needed for ./gradlew on first clone

# Full-article fetch cache (transient, large, regenerable). The small
# deterministic Wikidata datasets in cache/*.json ARE committed (instant regen).
tools/corpus/cache/articles/

# Android secrets — keystores + Firebase config out of git permanently
android/keystore/
*.jks
*.keystore
google-services.json
play-service-account.json
*.aab
*.apk

# IntelliJ / Android Studio
*.iml
.kotlin/

# Native debug symbols
native-debug-symbols.zip
